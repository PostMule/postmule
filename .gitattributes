* text=auto

# Windows scripts must have CRLF on checkout — PowerShell 5.1 here-strings require it
*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Always LF for everything else
*.py   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf

# Binaries — no conversion
*.png  binary
*.jpg  binary
*.ico  binary
*.exe  binary
*.whl  binary
